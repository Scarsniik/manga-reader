{
  "name": "scaramanga",
  "version": "0.14.3",
  "description": "A lightweight desktop application for learning Japanese through manga.",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scarsniik/manga-reader.git"
  },
  "main": "dist/electron/main.js",
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-electron.ps1",
    "prestart": "tsc -p tsconfig.json",
    "build": "vite build",
    "build:electron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-electron-dist.ps1 && tsc --project tsconfig.electron.json",
    "dev": "vite",
    "build:app": "npm run prestart && npm run build",
    "build:all": "npm run package:all",
    "backup:user-data": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup-user-data.ps1",
    "load:user-data": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/load-user-data.ps1",
    "scrapers:test": "node scripts/test-configured-scrapers.cjs",
    "test:reading-list-ordering": "npm run prestart && node --test scripts/reading-list-ordering.test.cjs",
    "test:saved-reading-list-update": "npm run build:electron && node --test scripts/saved-reading-list-update.test.cjs",
    "package:all": "npm run package:app:installer && npm run package:ocr-runtime",
    "package:app": "npm run package:app:installer",
    "package:app:installer": "npm run build:electron && npm run build && npm run clean:package && npx electron-builder --config electron-builder.config.cjs --win nsis --publish never",
    "package:app:portable": "npm run build:electron && npm run build && npm run clean:package && npx electron-builder --config electron-builder.config.cjs --win portable --publish never",
    "package:app:dir": "npm run build:electron && npm run build && npm run clean:package && npx electron-builder --config electron-builder.config.cjs --win dir --publish never",
    "package:win-unpacked": "npm run package:app:dir",
    "dev:electron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-electron.ps1",
    "electron:dev": "npm run dev:electron",
    "dev:electron:ocr-test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-electron-ocr-test.ps1",
    "dev:electron:ocr-test:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-electron-ocr-test.ps1 -ResetRuntimeState",
    "prepare:ocr-bundle": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-ocr-bundle.ps1",
    "prepare:ocr-bundle:force": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-ocr-bundle.ps1 -ForceRebuild",
    "ocr:test-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-local-ocr-runtime-test.ps1 -Force",
    "ocr:test-runtime:bundle": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-local-ocr-runtime-test.ps1 -Mode ExistingBundle -Force",
    "package:ocr-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-ocr-runtime.ps1 -Force",
    "package:ocr-runtime:force": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-ocr-runtime.ps1 -BuildBundle -ForceRebuild -Force",
    "zip:win-unpacked": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/zip-win-unpacked.ps1",
    "clean:package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-package.ps1",
    "release:app": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-app.ps1 -Publish",
    "release:app:dry-run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-app.ps1 -DryRun",
    "release:status": "node scripts/check-release-status.cjs",
    "prepackage": "npm run clean:package",
    "package": "npm run package:app",
    "dist": "npm run package:app"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "image-size": "^1.0.1",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.8",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "flag-icons": "^7.5.0",
    "linkedom": "^0.18.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-doctor": "^0.5.1",
    "react-router-dom": "^6.14.1",
    "sass": "^1.92.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vite-plugin-svgr": "^5.2.0"
  },
  "homepage": "https://github.com/Scarsniik/manga-reader",
  "license": "MIT"
}
